{
  "name": "hex-helper",
  "version": "1.0.1",
  "description": "英雄联盟海克斯大乱斗辅助工具",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.hexhelper.app",
    "productName": "HexHelper",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "hex_data.json",
      "augments_tier_map.json",
      "icon.png",
      "package.json",
      "node_modules/uiohook-napi/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "icon.png",
      "requestedExecutionLevel": "requireAdministrator",
      "artifactName": "HexHelper.exe"
    }
  },
  "keywords": [],
  "author": "HexHelper",
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "https": "^1.0.0",
    "uiohook-napi": "^1.5.5"
  }
}
